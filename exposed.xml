            <fr:route>guard.xml</fr:route>
            <fr:title text="Guard">Guard</fr:title>
            <fr:authors />
          </fr:frontmatter>
          <fr:mainmatter>
            <fr:p>Guard is a "refillable hp" which is reduced before damage reduces <fr:link type="local" href="virtues.xml" addr="virtues" title="Virtues">vigour</fr:link>.</fr:p>
            <fr:p>Restored fully upon a moment of piece after the danger has passed.</fr:p>
          </fr:mainmatter>
